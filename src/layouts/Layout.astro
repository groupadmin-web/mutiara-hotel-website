---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "Mutiara Hotel"
  : "Mutiara Hotel - Premium Accommodations";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description="Welcome to Mutiara Hotel. Book your stay with us directly for premium service and accommodation."
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Mutiara Hotel`,
          image: resolvedImageWithDomain,
        },
      }}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
  </head>
  <body>
    
    <div class="fixed top-4 right-4 z-[999999] pointer-events-auto sm:right-6 notranslate">
      <div class="bg-white/95 backdrop-blur-md px-3 py-1.5 rounded-full flex items-center gap-3 border border-slate-200/90 shadow-lg transition-all duration-300">
        
        <span id="global-lang-label" class="text-[9px] tracking-wide font-sans font-semibold text-slate-400 uppercase pr-0.5 select-none hidden xs:inline-block">
          SELECT LANGUAGE:
        </span>

        <div class="w-[1px] h-3 bg-slate-200 hidden xs:inline-block"></div>

        <button 
          id="global-nav-en" 
          type="button" 
          class="flex items-center gap-1.5 rounded-full transition-all duration-200 hover:scale-105 cursor-pointer select-none outline-none text-slate-400 font-sans font-bold text-xs"
          title="English"
        >
          <div class="w-4 h-4 rounded-full overflow-hidden shrink-0 aspect-square">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" preserveAspectRatio="none" class="w-full h-full object-cover block pointer-events-none">
              <clipPath id="s"><path d="M0 0h60v30H0z"/></clipPath>
              <g clip-path="url(#s)">
                <path d="M0 0h60v30H0z" fill="#012169"/>
                <path d="M0 0l60 30M60 0L0 30" stroke="#fff" stroke-width="6"/>
                <path d="M0 0l60 30M60 0L0 30" stroke="#c8102e" stroke-width="4"/>
                <path d="M30 0v30M0 15h60" stroke="#fff" stroke-width="10"/>
                <path d="M30 0v30M0 15h60" stroke="#c8102e" stroke-width="6"/>
              </g>
            </svg>
          </div>
          <span class="text-[11px] hidden sm:inline">EN</span>
        </button>

        <div class="w-[1px] h-3 bg-slate-200"></div>

        <button 
          id="global-nav-id" 
          type="button" 
          class="flex items-center gap-1.5 rounded-full transition-all duration-200 hover:scale-105 cursor-pointer select-none outline-none text-slate-400 font-sans font-bold text-xs"
          title="Indonesia"
        >
          <div class="w-4 h-4 rounded-full overflow-hidden shrink-0 aspect-square border border-slate-100">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3 2" preserveAspectRatio="none" class="w-full h-full object-cover block pointer-events-none">
              <path fill="#e21c0e" d="M0 0h3v1H0z"/>
              <path fill="#fff" d="M0 1h3v1H0z"/>
            </svg>
          </div>
          <span class="text-[11px] hidden sm:inline">ID</span>
        </button>

        <div class="w-[1px] h-3 bg-slate-200"></div>

        <button 
          id="global-nav-zh" 
          type="button" 
          class="flex items-center gap-1.5 rounded-full transition-all duration-200 hover:scale-105 cursor-pointer select-none outline-none font-sans font-bold text-xs"
          title="Chinese (Simplified)"
        >
          <div class="w-4 h-4 rounded-full overflow-hidden shrink-0 aspect-square">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 600" preserveAspectRatio="none" class="w-full h-full object-cover block pointer-events-none">
              <path fill="#de2110" d="M0 0h900v600H0z"/>
              <g fill="#ffde00">
                <path id="l" d="M150 200l29.4-90.4 77 56-95.2 3.1 29.4-90.5 40.6 81.8z"/>
                <use href="#l" transform="matrix(.2723 -.20422 .20422 .2723 150 -100)"/>
                <use href="#l" transform="matrix(.13615 -.31548 .31548 .13615 210 -40)"/>
                <use href="#l" transform="matrix(.01923 -.34237 .34237 .01923 230 60)"/>
                <use href="#l" transform="matrix(-.1118 -.32475 .32475 -.1118 190 140)"/>
              </g>
            </svg>
          </div>
          <span id="label-zh-text" class="text-[11px] tracking-wide transition-colors duration-200">中文</span>
        </button>

      </div>
    </div>

    <Navbar />

    <main id="universal-translation-root">
      <slot />
    </main>

    <Footer />

    <a href="https://wa.me/6287722469110" class="whatsapp-icon-float notranslate" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 24 24" class="whatsapp-svg">
        <path fill="#FFF" d="M12.012 2c-5.508 0-9.988 4.479-9.988 9.987 0 1.763.459 3.49 1.33 5.009l-1.353 4.937 5.055-1.326c1.47.8 3.125 1.222 4.814 1.223h.004c5.507 0 9.989-4.479 9.989-9.988 0-2.67-1.039-5.18-2.93-7.071C17.186 3.04 14.684 2 12.012 2zm5.7

---
// src/components/archive.astro
import storiesData from "@/content/stories.json";

const rawStories = storiesData || [];
const today = new Date();

const archivedStories = rawStories.filter(story => {
  const expiry = story.expiry_date ? new Date(story.expiry_date) : null;
  return expiry && expiry < today;
});
---

{archivedStories.length > 0 && (
  <section class="py-12 max-w-7xl mx-auto px-6 font-sans overflow-hidden">
    <div class="pt-4 border-t border-slate-200 max-w-4xl">
      <div class="mb-8">
        <h4 class="font-serif text-2xl text-slate-800 font-normal">Past Events & Announcements</h4>
        <div class="w-12 h-0.5 bg-slate-300 mt-2"></div>
      </div>
      
      <div class="space-y-4">
        {archivedStories.map(story => (
          <details class="archive-accordion group bg-slate-50/60 rounded-xl border border-slate-100/80 outline-none transition-all duration-300 open:bg-white open:shadow-md open:border-slate-200">
            
            <summary class="flex items-center gap-4 p-4 list-none cursor-pointer select-none outline-none focus:outline-none">
              <div class="w-20 sm:w-24 h-16 shrink-0 rounded-lg overflow-hidden bg-slate-200 border border-slate-100 shadow-inner">
                {story.story_image && (
                  <img 
                    src={story.story_image} 
                    alt={story.title} 
                    class="archive-thumb w-full h-full object-cover grayscale opacity-80 transition-all duration-500 group-open:grayscale-0 group-open:opacity-100 group-hover:scale-105" 
                  />
                )}
              </div>

              <div class="flex-grow min-w-0 entry-header-wrapper">
                <div class="flex flex-wrap items-center gap-x-2.5 mb-0.5">
                  <span class="text-[9px] font-bold tracking-wider text-slate-400 uppercase">
                    {story.subtitle || "PAST EVENT"}
                  </span>
                  {story.expiry_date && (
                    <span class="text-[10px] text-slate-400/70 font-sans font-light">
                      • Concluded {new Date(story.expiry_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                    </span>
                  )}
                </div>
                
                <h5 class="font-serif text-base text-slate-800 font-medium transition-colors duration-200 group-hover:text-amber-600 group-open:text-slate-900 group-open:font-semibold">
                  {story.title}
                </h5>
              </div>

              <div class="shrink-0 text-slate-400 pr-2 transition-transform duration-300 transform group-open:rotate-180">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>

            <div class="px-4 pb-5 pt-1 sm:pl-[7.5rem] border-t border-dashed border-slate-100 mt-1 transition-all duration-300 animate-fadeIn">
              <p class="text-slate-600 text-sm leading-relaxed font-light tracking-wide max-w-2xl whitespace-pre-line">
                {story.text_content}
              </p>
            </div>

          </details>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  summary::-webkit-details-marker { display: none; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn { animation: fadeIn 0.25s ease-out forwards; }
</style>

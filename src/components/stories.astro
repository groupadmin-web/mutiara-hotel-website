---
import storiesData from "@/content/stories.json";

const rawStories = storiesData || [];
const today = new Date();

const activeStories = rawStories.filter(story => {
  const start = story.start_date ? new Date(story.start_date) : null;
  const expiry = story.expiry_date ? new Date(story.expiry_date) : null;
  if (start && start > today) return false;
  if (expiry && expiry < today) return false;
  return true;
});

const archivedStories = rawStories.filter(story => {
  const expiry = story.expiry_date ? new Date(story.expiry_date) : null;
  return expiry && expiry < today;
});
---

<section class="py-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 font-sans overflow-hidden" id="smart-story-section">
  
  <div class="space-y-20 md:space-y-28">
    {
      activeStories.map((story, index) => {
        const isEven = index % 2 === 0;
        return (
          /* DYNAMIC LINGUISTIC NODE */
          <div class="story-card-node grid lg:grid-cols-12 items-center gap-8 md:gap-12 lg:gap-16 bg-slate-50/40 p-6 md:p-8 rounded-2xl border border-slate-100/80 relative">
            
            {/* PHOTO COMPONENT FRAME */}
            <div class={`lg:col-span-5 aspect-[4/3] rounded-xl overflow-hidden bg-slate-100 shadow-sm transition-all duration-700 hover:shadow-md ${isEven ? 'lg:order-1' : 'lg:order-2'}`}>
              {story.story_image && (
                <img 
                  src={story.story_image} 
                  alt={story.title} 
                  class="w-full h-full object-cover transition-transform duration-700 hover:scale-103" 
                  loading="lazy" 
                />
              )}
            </div>
            
            {/* TEXT COMPONENT FRAME WITH AUTOMATIC LOCALE OVERRIDE */}
            <div class={`lg:col-span-7 flex flex-col justify-center py-2 ${isEven ? 'lg:order-2' : 'lg:order-1'}`}>
              
              <div class="flex justify-end items-center gap-2 mb-4 border-b border-slate-100/60 pb-3">
                <span class="text-[10px] tracking-wider text-slate-400 font-medium uppercase">Language Mode:</span>
                <div class="inline-flex rounded-md bg-slate-100 p-0.5">
                  <button class="card-toggle-btn active-btn px-2 py-0.5 text-[11px] font-semibold rounded bg-white text-slate-900 shadow-sm" data-mode="original">
                    Original
                  </button>
                  <button class="card-toggle-btn target-translate-btn px-2 py-0.5 text-[11px] font-semibold rounded text-slate-500 hover:text-slate-900" data-mode="translate">
                    ✨ AI Loading...
                  </button>
                </div>
              </div>

              <div class="story-text-container">
                {story.subtitle && (
                  <span class="text-xs font-semibold tracking-[0.22em] text-amber-600 uppercase mb-2.5 block translatable-item">
                    {story.subtitle}
                  </span>
                )}
                <h3 class="font-serif text-2xl md:text-3xl text-slate-900 tracking-wide font-normal mb-4 leading-snug translatable-item">
                  {story.title}
                </h3>
                <p class="text-slate-600 text-[14px] md:text-[15px] leading-relaxed font-light tracking-wide translatable-item">
                  {story.text_content}
                </p>
              </div>
            </div>

          </div>
        );
      })
    }
  </div>

  {archivedStories.length > 0 && (
    <div class="mt-28 pt-16 border-t border-slate-100">
      <div class="text-center mb-12">
        <h4 class="font-serif text-2xl text-slate-800 font-normal">Past Events & Announcements</h4>
        <p class="text-sm text-slate-400 mt-1">A historical log of Mutiara corporate features and seasonal gatherings</p>
      </div>
      
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
        {archivedStories.map(story => (
          <div class="story-card-node bg-slate-50/50 rounded-xl p-4 border border-slate-100 opacity-80 hover:opacity-100 transition-opacity flex flex-col justify-between h-full">
            <div>
              <div class="aspect-video w-full rounded-lg overflow-hidden bg-slate-200 mb-4">
                {story.story_image && <img src={story.story_image} alt={story.title} class="w-full h-full object-cover grayscale" />}
              </div>
              
              <div class="flex justify-end items-center gap-1.5 mb-3 border-b border-slate-200/40 pb-2">
                <button class="card-toggle-btn active-btn text-[9px] font-bold uppercase rounded px-1.5 py-0.5 bg-white text-slate-900 shadow-sm" data-mode="original">Orig</button>
                <button class="card-toggle-btn target-translate-btn text-[9px] font-bold uppercase rounded px-1.5 py-0.5 text-slate-500" data-mode="translate">✨ AI</button>
              </div>

              <div class="story-text-container">
                <span class="text-[10px] font-bold tracking-wider text-slate-400 uppercase block mb-1 translatable-item">{story.subtitle || "ARCHIVE"}</span>
                <h5 class="font-serif text-base text-slate-800 font-medium mb-2 leading-snug translatable-item">{story.title}</h5>
                <p class="text-slate-500 text-xs leading-relaxed font-light line-clamp-3 translatable-item">{story.text_content}</p>
              </div>
            </div>
            {story.expiry_date && (
              <span class="text-[10px] text-amber-600/70 font-sans mt-4 block border-t border-slate-200/60 pt-2 font-medium">
                Concluded on: {new Date(story.expiry_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            )}
          </div>
        ))}
      </div>
    </div>
  )}
</section>

<script>
  const storyCards = document.querySelectorAll('.story-card-node');
  const translationCache = new Map();

  // 1. DETECT USER BROWSER SETTINGS GLOBAL TARGET
  // Pulls standard codes like 'id', 'en', 'zh', etc.
  const userBrowserLocale = (navigator.language || navigator.languages[0] || 'id').toLowerCase().split('-')[0];

  async function callTranslateEngine(text, targetLang) {
    try {
      const response = await fetch(`https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`);
      if (!response.ok) return text;
      const data = await response.json();
      return data[0].map(x => x[0]).join('');
    } catch (e) {
      return text;
    }
  }

  storyCards.forEach(card => {
    const toggleButtons = card.querySelectorAll('.card-toggle-btn');
    const translateButton = card.querySelector('.target-translate-btn');
    const translatableElements = card.querySelectorAll('.translatable-item');
    
    let originalStorage = new Map();
    translatableElements.forEach((el, i) => {
      originalStorage.set(i, el.innerHTML);
    });

    // 2. RUN CARD TEXT SCANNER (Detect if this card's text is Indonesian or English)
    const sampleText = translatableElements[1] ? translatableElements[1].textContent || "" : "";
    const isCardIndonesian = /\b(dan|yang|kamar|dengan|di|ke|untuk|kami|bisa|fasilitas)\b/i.test(sampleText);
    const cardBaseLangCode = isCardIndonesian ? 'id' : 'en';
    const localOppositeLangCode = isCardIndonesian ? 'en' : 'id';
    
    // Set explicit visual button target indicator states
    if (translateButton) {
      translateButton.textContent = isCardIndonesian ? "English (AI)" : "Indonesia (AI)";
    }

    // Execution routine framework helper
    async function triggerTranslationRun(targetBtn) {
      targetBtn.classList.add('animate-pulse');
      
      toggleButtons.forEach(b => {
        b.classList.remove('bg-white', 'text-slate-900', 'shadow-sm');
        b.classList.add('text-slate-500');
      });
      targetBtn.classList.add('bg-white', 'text-slate-900', 'shadow-sm');
      targetBtn.classList.remove('text-slate-500');

      for (let i = 0; i < translatableElements.length; i++) {
        const el = translatableElements[i];
        const rawSourceString = originalStorage.get(i).trim();

        if (!rawSourceString) continue;

        if (translationCache.has(rawSourceString + '-' + userBrowserLocale)) {
          el.innerHTML = translationCache.get(rawSourceString + '-' + userBrowserLocale);
        } else {
          const pureStringText = el.textContent || el.innerText;
          const outputTranslation = await callTranslateEngine(pureStringText, userBrowserLocale);
          translationCache.set(rawSourceString + '-' + userBrowserLocale, outputTranslation);
          el.innerHTML = outputTranslation;
        }
      }
      targetBtn.classList.remove('animate-pulse');
    }

    // 3. AUTO-TRIGGER LOGIC: If browser language doesn't match content language, flip it!
    // Example: User browser is 'en' but card is written in 'id' -> Translate it immediately.
    if (userBrowserLocale !== cardBaseLangCode && (userBrowserLocale === 'id' || userBrowserLocale === 'en') && translateButton) {
      // Small delayed execution step to let the document paint baseline elements first cleanly
      setTimeout(() => {
        triggerTranslationRun(translateButton);
      }, 400);
    }

    // 4. MANUAL FALLBACK EVENT LISTENERS (If user still wants to toggle manually)
    toggleButtons.forEach(btn => {
      btn.addEventListener('click', async () => {
        const mode = btn.getAttribute('data-mode');

        if (mode === 'original') {
          toggleButtons.forEach(b => {
            b.classList.remove('bg-white', 'text-slate-900', 'shadow-sm');
            b.classList.add('text-slate-500');
          });
          btn.classList.add('bg-white', 'text-slate-900', 'shadow-sm');
          btn.classList.remove('text-slate-500');
          
          translatableElements.forEach((el, i) => {
            el.innerHTML = originalStorage.get(i);
          });
        } else {
          triggerTranslationRun(btn);
        }
      });
    });
  });
</script>

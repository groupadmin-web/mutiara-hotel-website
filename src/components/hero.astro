---
// src/components/hero.astro
import homepageData from "../content/homepage.json";

// Extract content text fields and the single hero image path safely
const { welcome_title, tagline, booking_button_text, hero_image } = homepageData;

// Fallback background image if none is selected
const backgroundImage = hero_image || "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=1920&q=80";
---

<main class="relative bg-gray-950 text-white min-h-[80vh] w-full flex items-center justify-center overflow-hidden shadow-2xl">
  
  <div class="absolute inset-0 z-0 w-full h-full">
    <img 
      src={backgroundImage} 
      alt="Mutiara Hotel Showcase Background" 
      class="absolute inset-0 w-full h-full object-cover filter brightness-50 opacity-40"
    />
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center px-6 py-24 flex flex-col items-center justify-center">
    
    <h1 class="text-5xl md:text-7xl font-serif font-bold tracking-wide mb-8 uppercase drop-shadow-[0_4px_8px_rgba(0,0,0,0.8)]">
      {welcome_title || "MUTIARA HOTEL & CONVENTION"}
    </h1>
    
    <div class="space-y-4 max-w-2xl mb-10 text-gray-100 font-light drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">
      <p class="text-xl md:text-2xl italic font-serif leading-relaxed">
        "{tagline || "Our hotel blends the charm of modern hospitality and the sophistication of the colonial era boutique hotel."}"
      </p>
      <p class="text-base md:text-lg opacity-90 font-sans tracking-wide">
        Mutiara Hotel offers rooms with a capacity of 2-4 people, providing comfortable accommodations for individuals, couples, and groups of various sizes.
      </p>
    </div>

    <div class="flex justify-center w-full">
      <a 
        href="https://m.mutiarahotel.com" 
        class="bg-amber-600 hover:bg-amber-700 text-white font-bold text-base md:text-lg px-6 py-3.5 rounded-lg shadow-xl hover:shadow-2xl transition-all transform hover:-translate-y-0.5 flex items-center justify-center gap-2.5 tracking-wide min-w-[220px]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 md:w-6 md:h-6 shrink-0 text-amber-100">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
        </svg>
        <span>{booking_button_text || "Book Now"}</span>
      </a>
    </div>

  </div>
</main>

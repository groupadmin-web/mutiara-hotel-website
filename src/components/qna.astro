---
// src/components/qna.astro
import qnaData from "@/content/qna.json";

// Safely resolve the data parameters with fallback values
const qna = qnaData || {};
const faqItems = qna.faqs || [];
---

<section class="my-24 px-6 max-w-4xl mx-auto">
  <div class="text-center max-w-xl mx-auto mb-12">
    <h2 class="text-3xl font-serif font-bold text-gray-800 mb-2">
      {qna.section_title || "Frequently Asked Questions"}
    </h2>
    <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-4"></div>
    <p class="text-sm text-gray-500 font-sans leading-relaxed">
      {qna.section_subtitle || "Find quick answers regarding your upcoming heritage stay."}
    </p>
  </div>

  {/* INTERACTIVE ACCORDION BLOCK GROUP */}
  <div class="space-y-4">
    {faqItems.map((item, index) => (
      <details class="group bg-white rounded-xl border border-gray-200 shadow-sm transition-all duration-300 open:border-amber-500/40 open:shadow-md">
        <summary class="flex items-center justify-between font-sans font-semibold text-sm md:text-base text-gray-800 p-5 cursor-pointer list-none select-none hover:text-amber-600 transition-colors">
          <span>{item.question}</span>
          <span class="transition-transform duration-300 group-open:rotate-180 text-amber-500 shrink-0 ml-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="px-5 pb-5 font-sans text-xs md:text-sm text-gray-600 leading-relaxed border-t border-gray-50 pt-3 animate-fadeIn">
          <p>{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  /* Standard modern marker concealment rules */
  summary::-webkit-details-marker { display: none; }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn { animation: fadeIn 0.25s ease-out; }
</style>

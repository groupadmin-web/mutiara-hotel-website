---
import Container from "@/components/container.astro";

// Fetch your dynamic hotel brand payload data directly from your configuration engine
import homepageData from "@/content/homepage.json";

const currentYear = new Date().getFullYear();
---

{/* UNIVERSAL FOOTER TRACKER: id="footer" matches your new navbar.astro jump routing perfectly */}
<footer id="footer" class="bg-slate-900 text-white pt-16 pb-8 border-t border-slate-800 font-sans clear-both block w-full">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 pb-12 border-b border-slate-800">
      
      <div class="space-y-4">
        <h3 class="font-serif font-bold text-xl tracking-wider text-amber-500 uppercase">
          {homepageData.logo_text || "MUTIARA"}
        </h3>
        <p class="text-xs text-slate-400 leading-relaxed max-w-sm">
          An authentic urban gateway established in the heart of Bandung, blending classic heritage architecture with sophisticated contemporary hospitality assets.
        </p>
      </div>

      <div class="space-y-4">
        <h4 class="text-xs font-bold tracking-widest text-slate-300 uppercase">Guest Services</h4>
        <ul class="space-y-2.5 text-sm text-slate-400">
          <li>
            <a href="/rooms" class="hover:text-amber-500 transition-colors">Our Suites & Rooms</a>
          </li>
          <li>
            <a href="/meetings-events" class="hover:text-amber-500 transition-colors">Convention & Meeting Venues</a>
          </li>
          <li>
            <a href="/gallery" class="hover:text-amber-500 transition-colors">Historical Art Gallery</a>
          </li>
          <li>
            <a href="/attractions" class="hover:text-amber-500 transition-colors">Local Sightseeing Guides</a>
          </li>
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="text-xs font-bold tracking-widest text-slate-300 uppercase">Instant Desks</h4>
        <ul class="space-y-3 text-xs text-slate-400">
          <li class="flex items-start gap-2">
            <span class="text-emerald-500 font-bold shrink-0 notranslate">WA:</span>
            <a 
              href="https://wa.me/6287722469110?text=Hi%20Mutiara%20Hotel,%20I%20would%20like%20to%20inquire%20about%20room%20availability." 
              target="_blank" 
              rel="noopener noreferrer" 
              class="hover:text-emerald-400 font-medium transition-colors"
            >
              +62 877-2246-9110 (Front Desk)
            </a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-500 font-bold shrink-0 notranslate">WA:</span>
            <a 
              href="https://wa.me/6287722469110?text=Hi%20Mutiara%20Marketing,%20I%20would%20like%20to%20request%20an%20event%20proposal." 
              target="_blank" 
              rel="noopener noreferrer" 
              class="hover:text-amber-400 font-medium transition-colors"
            >
              +62 877-2246-9110 (Marketing Office)
            </a>
          </li>
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="text-xs font-bold tracking-widest text-slate-300 uppercase">Location Address</h4>
        <p class="text-xs text-slate-400 leading-relaxed notranslate">
          Mutiara Hotel & Convention<br />
          Jalan Kebon Kawung No. 60,<br />
          Pasir Kaliki, Cicendo, Bandung City,<br />
          West Java 40171, Indonesia
        </p>
      </div>

    </div>

    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <p class="font-sans">
        &copy; {currentYear} Mutiara Hotel & Convention Center Bandung. All Rights Reserved.
      </p>
      <div class="flex gap-6 font-sans">
        <a href="https://m.mutiarahotel.com" class="hover:text-amber-500 transition-colors">Direct Portal Access</a>
        <span class="text-slate-700">|</span>
        <span class="text-slate-600 uppercase tracking-widest text-[10px]">Secure Hub Blueprint</span>
      </div>
    </div>
  </Container>
</footer>

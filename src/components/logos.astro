---
import homepageData from "@/content/homepage.json";
import badgesData from "@/content/badges.json";

const showPartnersRow = homepageData.show_partners !== false;
const safeBadges = badgesData || [];

// Master logo resource assets
const officialLogos = {
  traveloka: "https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/Traveloka_Logo.svg/320px-Traveloka_Logo.svg.png"
};
---

{showPartnersRow && (
  <div class="mt-28 mb-20 max-w-6xl mx-auto px-6 font-sans">
    
    <p class="text-center text-xs font-bold tracking-[0.25em] text-slate-400 uppercase mb-12 select-none">
      Official Reservation Channels & Verification Partners
    </p>

    {/* SCATTERED FLEX COLLAGE COMPONENT */}
    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-10 md:gap-x-16 md:gap-y-12 max-w-5xl mx-auto">
      {safeBadges.map((badge, index) => {
        const staffTypedName = (badge.name || "").toLowerCase().trim();
        
        // Mathematical offset calculations to alternate positions automatically based on array position
        // This gives the logos a natural, staggered "jumbled" alignment without breaking responsive flows
        const isEven = index % 2 === 0;
        const isThird = index % 3 === 0;
        const staggerClass = isThird ? "md:-translate-y-2" : isEven ? "md:translate-y-2" : "md:translate-y-0";
        const rotateClass = isThird ? "md:-rotate-1" : isEven ? "md:rotate-1" : "md:rotate-0";

        return (
          <div class={`flex flex-col items-center justify-center text-center group transition-all duration-300 transform ${staggerClass} ${rotateClass} hover:!translate-y-0 hover:!rotate-0 hover:scale-105 shrink-0 min-w-[125px]`}>
            
            {/* BRAND LOGO FRAME CONTAINER */}
            <div class="h-10 w-full flex items-center justify-center mb-2 filter grayscale opacity-45 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500">
              
              {staffTypedName.includes("booking") && (
                <div class="bg-[#003580] text-white px-3 py-1 rounded font-sans font-bold tracking-tight text-xs shadow-sm">Booking.com</div>
              )}

              {staffTypedName.includes("traveloka") && (
                <img src={officialLogos.traveloka} alt="Traveloka" class="max-h-5 object-contain" />
              )}

              {staffTypedName.includes("agoda") && (
                <div class="flex flex-col items-center scale-85 transform">
                  <span class="text-2xl font-normal tracking-tight text-slate-700 lowercase leading-none">agoda</span>
                  <div class="flex gap-1 mt-1 justify-center">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#f43f5e]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#eab308]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#10b981]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#0ea5e9]"></span>
                  </div>
                </div>
              )}

              {staffTypedName.includes("google") && (
                <div class="flex items-center gap-1 text-sm font-bold text-slate-600 tracking-tight">
                  <span class="text-blue-500 text-base">G</span><span class="text-red-500">o</span><span class="text-yellow-500">o</span><span class="text-blue-500">g</span><span class="text-green-500">l</span><span class="text-red-500">e</span>
                </div>
              )}

              {staffTypedName.includes("tripadvisor") && (
                <div class="flex items-center gap-1 text-xs font-black text-[#004f32]">
                  <span class="text-sky-500 text-base">🦉</span><span>tripadvisor</span>
                </div>
              )}

              {(staffTypedName.includes("trip.com") || staffTypedName.includes("trip")) && !staffTypedName.includes("advisor") && (
                <span class="text-base font-black tracking-tight text-blue-600 font-sans">Trip<span class="text-amber-500">.com</span></span>
              )}

              {staffTypedName.includes("ctrip") && (
                <div class="flex flex-col items-center leading-none">
                  <span class="text-sm font-extrabold tracking-wide text-slate-700 font-sans">Ctrip</span>
                  <span class="text-[9px] tracking-widest text-slate-400 font-medium scale-90 mt-0.5">携程旅行</span>
                </div>
              )}

              {!staffTypedName.includes("booking") && !staffTypedName.includes("traveloka") && !staffTypedName.includes("agoda") && !staffTypedName.includes("google") && !staffTypedName.includes("tripadvisor") && !staffTypedName.includes("trip") && !staffTypedName.includes("ctrip") && (
                <span class="text-xs font-bold tracking-wider text-slate-600 uppercase font-serif">🏆 {badge.name}</span>
              )}
              
            </div>

            {/* DYNAMIC METRIC SUBTITLE TEXT */}
            {badge.subtitle && (
              <span class="text-[10px] font-semibold tracking-wide text-slate-400 group-hover:text-amber-700 transition-colors duration-300">
                {badge.subtitle}
              </span>
            )}
            
          </div>
        );
      })}
    </div>
    
    <div class="h-[1px] w-full bg-gradient-to-r from-transparent via-slate-200/60 to-transparent mt-20"></div>
  </div>
)}

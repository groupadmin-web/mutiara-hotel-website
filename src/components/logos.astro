---
import homepageData from "@/content/homepage.json";
import badgesData from "@/content/badges.json";

const showPartnersRow = homepageData.show_partners !== false;
const safeBadges = badgesData || [];

// Master logo resource assets
const officialLogos = {
  traveloka: "https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/Traveloka_Logo.svg/320px-Traveloka_Logo.svg.png"
};
---

{showPartnersRow && (
  /* ADDED PROTECTION: The 'notranslate' class completely locks this row to prevent language changes */
  <div class="mt-24 mb-16 max-w-7xl mx-auto px-6 font-sans notranslate">
    
    <p class="text-center text-xs font-bold tracking-[0.25em] text-slate-500 uppercase mb-12 select-none">
      Official Reservation Channels & Verification Partners
    </p>

    {/* PERFECTLY HORIZONTAL FLEX CARPET */}
    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-10 md:gap-x-14 max-w-6xl mx-auto">
      {safeBadges.map((badge) => {
        const staffTypedName = (badge.name || "").toLowerCase().trim();

        return (
          <div class="flex flex-col items-center justify-center text-center shrink-0 min-w-[130px] transition-transform duration-300 hover:-translate-y-0.5">
            
            {/* PRISTINE FULL-COLOR LOGO CONTAINER */}
            <div class="h-10 w-full flex items-center justify-center mb-2.5">
              
              {/* BOOKING.COM MATCH */}
              {staffTypedName.includes("booking") && (
                <div class="bg-[#003580] text-white px-3 py-1 rounded font-sans font-bold tracking-tight text-xs shadow-sm select-none">
                  Booking.com
                </div>
              )}

              {/* TRAVELOKA MATCH WITH SCRIPT FALLBACK */}
              {staffTypedName.includes("traveloka") && (
                <img 
                  src={officialLogos.traveloka} 
                  alt="Traveloka" 
                  class="max-h-5 object-contain select-none" 
                  loading="lazy"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                />
                <span class="text-lg font-black tracking-tight italic font-sans text-sky-600 select-none hidden">
                  traveloka
                </span>
              )}

              {/* AGODA MATCH */}
              {staffTypedName.includes("agoda") && (
                <div class="flex flex-col items-center select-none scale-90">
                  <span class="text-2xl font-normal tracking-tight text-slate-800 lowercase leading-none">agoda</span>
                  <div class="flex gap-1 mt-1 justify-center">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#f43f5e]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#eab308]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#10b981]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7]"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#0ea5e9]"></span>
                  </div>
                </div>
              )}

              {/* GOOGLE MATCH */}
              {staffTypedName.includes("google") && (
                <div class="flex items-center gap-0.5 text-sm font-bold tracking-tight select-none">
                  <span class="text-[#4285F4] text-base">G</span>
                  <span class="text-[#EA4335]">o</span>
                  <span class="text-[#FBBC05]">o</span>
                  <span class="text-[#4285F4]">g</span>
                  <span class="text-[#34A853]">l</span>
                  <span class="text-[#EA4335]">e</span>
                </div>
              )}

              {/* TRIPADVISOR MATCH */}
              {staffTypedName.includes("tripadvisor") && (
                <div class="flex items-center gap-1 text-xs font-black text-[#004f32] select-none">
                  <span class="text-lg">🦉</span>
                  <span class="tracking-tight">tripadvisor</span>
                </div>
              )}

              {/* TRIP.COM MATCH */}
              {(staffTypedName.includes("trip.com") || staffTypedName.includes("trip")) && !staffTypedName.includes("advisor") && (
                <span class="text-base font-black tracking-tight text-[#2563EB] font-sans select-none">
                  Trip<span class="text-[#F59E0B]">.com</span>
                </span>
              )}

              {/* CTRIP MATCH */}
              {staffTypedName.includes("ctrip") && (
                <div class="flex flex-col items-center leading-none select-none">
                  <span class="text-sm font-extrabold tracking-wide text-[#1E3A8A] font-sans">Ctrip</span>
                  <span class="text-[9px] tracking-widest text-slate-500 font-semibold mt-0.5">携程旅行</span>
                </div>
              )}

              {/* CUSTOM AWARD FALLBACK */}
              {!staffTypedName.includes("booking") && !staffTypedName.includes("traveloka") && !staffTypedName.includes("agoda") && !staffTypedName.includes("google") && !staffTypedName.includes("tripadvisor") && !staffTypedName.includes("trip") && !staffTypedName.includes("ctrip") && (
                <span class="text-xs font-bold tracking-wider text-amber-800 uppercase font-serif">🏆 {badge.name}</span>
              )}
              
            </div>

            {/* CRISP SUBTITLE TEXT */}
            {badge.subtitle && (
              <span class="text-[11px] font-semibold tracking-wide text-slate-600">
                {badge.subtitle}
              </span>
            )}
            
          </div>
        );
      })}
    </div>
    
    <div class="h-[1px] w-full bg-gradient-to-r from-transparent via-slate-200 to-transparent mt-16"></div>
  </div>
)}

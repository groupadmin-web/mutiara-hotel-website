---
// src/components/meetings.astro
import eventData from "../content/events.json";
const events = Array.isArray(eventData) ? eventData : [];
---

<section
  id="venues"
  class="scroll-mt-24 bg-slate-50 py-20 px-6 border-y border-slate-100">
  <div class="max-w-7xl mx-auto">
    {/* Section Header */}
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span
        class="text-amber-600 font-bold text-xs uppercase tracking-widest bg-amber-50 px-3 py-1 rounded-full"
        >Venues & Celebrations</span
      >
      <h2
        class="text-3xl md:text-4xl font-serif font-bold text-slate-900 mt-3 mb-4">
        Mutiara Convention Center
      </h2>
      <div class="h-0.5 w-16 bg-amber-500 mx-auto mb-4"></div>
      <p class="text-slate-600 text-sm md:text-base">
        Host your premium corporate galas, executive board meetings, grand
        weddings, or social banquets in the heart of Bandung.
      </p>
    </div>

    {/* Dynamic Grid Layout */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        events.map((event: any, index) => {
          // 1. Unpack all CMS values cleanly at the start of the loop
          const { hall_name, image, capacity_theater, main_feature, features } =
            event;

          return (
            <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-slate-100 overflow-hidden flex flex-col justify-between transition-all duration-300 transform hover:-translate-y-1">
              <div>
                {/* Visual Media Frame */}
                <div class="relative overflow-hidden aspect-[4/3] bg-slate-200">
                  {image ? (
                    <img
                      src={image}
                      alt={hall_name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : (
                    <div class="w-full h-full flex flex-col items-center justify-center bg-slate-900 text-slate-400 p-6 text-center">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="w-8 h-8 text-amber-500 mb-2">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
                        />
                      </svg>
                      <span class="text-xs font-serif tracking-wider text-slate-300">
                        {hall_name} Preview
                      </span>
                    </div>
                  )}
                  <div class="absolute top-4 right-4 bg-slate-900/80 text-white text-[10px] tracking-widest uppercase px-3 py-1.5 rounded-md font-sans">
                    Theater Seating Setup
                  </div>
                </div>

                {/* Space Summary Metrics Row */}
                <div class="flex items-center justify-between border-b border-slate-50 bg-slate-50/50 px-6 py-3 text-xs text-slate-500 font-medium">
                  <span class="flex items-center gap-1.5">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke="currentColor"
                      class="w-4 h-4 text-slate-400">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"
                      />
                    </svg>
                    Max {capacity_theater || "Contact Desk"} Pax
                  </span>
                  <span class="inline-block bg-amber-50 text-amber-700 text-[9px] px-2.5 py-0.5 rounded-full font-sans uppercase tracking-wider font-semibold">
                    Premium Space
                  </span>
                </div>

                {/* Card Descriptions */}
                <div class="p-6">
                  <h3 class="font-serif font-bold text-xl text-slate-900 mb-2 group-hover:text-amber-600 transition-colors">
                    {hall_name}
                  </h3>
                  <p class="text-[11px] text-amber-600 font-bold tracking-wider uppercase mb-3 flex items-center gap-1">
                    <span>•</span> Highlight: {main_feature}
                  </p>

                  {/* DYNAMIC AMENITY PILL MATRIX */}
                  {features && Array.isArray(features) && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {features.map((feature: string) => (
                        <span class="text-[11px] font-semibold text-slate-700 bg-slate-100 border border-slate-200/60 px-2.5 py-1 rounded-md">
                          {feature}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>

              {/* Action Trigger Link */}
              <div class="px-6 pb-6 pt-0 mt-auto">
                <button
                  type="button"
                  data-open-event-modal={index}
                  class="block w-full bg-slate-900 hover:bg-amber-600 text-white text-center font-bold text-xs py-3.5 rounded-xl tracking-wider uppercase cursor-pointer shadow-sm group-hover:shadow-md transition-all duration-300">
                  View Space Gallery
                </button>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
